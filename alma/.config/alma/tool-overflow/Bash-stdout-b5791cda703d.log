#!/usr/bin/env python3
"""
ATom vs GEOS-Chem CO Vertical Profile — v2 修正版
=====================================================
修复：GC廓线不再只是ATom所在气压层的单点插值，
而是提取所有匹配格点的完整垂直列，统计整列在各高度bin的分布。

方法：
  ATom侧：每个观测点 → 按GPS高度分bin → 中位数±IQR
  GC侧：对每个唯一(day, ilat, ilon)格点，提取完整47层廓线，
        按气压-高度换算后统计各高度bin的中位数±IQR
  去重：同一个GC格点只提取一次，避免重复计数
"""

import numpy as np
import netCDF4 as nc
import matplotlib.pyplot as plt
import matplotlib.ticker as mticker
import datetime
from scipy.interpolate import interp1d

plt.rcParams.update({
    'font.family': 'DejaVu Sans',
    'axes.labelsize': 11, 'axes.titlesize': 12,
    'xtick.labelsize': 9, 'ytick.labelsize': 9,
    'legend.fontsize': 9, 'figure.dpi': 150,
})

# ── 1. 载入 GEOS-Chem ─────────────────────────────────────────────
print("Loading GEOS-Chem …")
ds_gc   = nc.Dataset('GEOSChem.SpeciesConc.2017-whole_year.nc')
gc_lat  = ds_gc['lat'][:]
gc_lon  = ds_gc['lon'][:]
gc_lev  = ds_gc['lev'][:]
gc_co   = ds_gc['CO_day'][:] * 1e9          # (365,47,lat,lon) ppb
gc_pres = gc_lev * 1013.25                   # eta → approximate hPa

# 将 GC 47层气压转换为近似高度（标准大气）
gc_alt_km = np.array([
    7.4 * np.log(1013.25 / max(p, 0.01)) for p in gc_pres
])

# ── 2. 高度 bins ──────────────────────────────────────────────────
alt_edges   = np.arange(0, 13, 1)
alt_centers = 0.5 * (alt_edges[:-1] + alt_edges[1:])
N_BINS      = len(alt_centers)
MIN_PTS     = 5

ref_date   = datetime.datetime(2016, 1, 1)
y2017_start= datetime.datetime(2017, 1, 1)

campaigns = {
    'ATom-2': {
        'file'   : 'ATom-data/MER10_DC8_ATom-2.nc',
        'label'  : 'ATom-2  (Jan–Feb 2017)',
        'color_a': '#2166ac',
        'color_m': '#d94801',
    },
    'ATom-3': {
        'file'   : 'ATom-data/MER10_DC8_ATom-3.nc',
        'label'  : 'ATom-3  (Sep–Oct 2017)',
        'color_a': '#2166ac',
        'color_m': '#d94801',
    },
}

results = {}

for camp, info in campaigns.items():
    print(f"\n{'─'*55}\n  Campaign : {camp}")
    ds  = nc.Dataset(info['file'])
    mms = ds['MMS']

    time_raw = ds['time'][:]
    co_obs   = ds['CO.X'][:]
    g_alt    = mms['G_ALT'][:]
    g_lat    = mms['G_LAT'][:]
    g_lon    = mms['G_LONG'][:]
    p_obs    = mms['P'][:]

    times   = np.array([ref_date + datetime.timedelta(seconds=float(t))
                        for t in time_raw])
    doy_arr = np.array([(t - y2017_start).days for t in times])

    # 有效掩码
    valid = (
        (co_obs  >  0)  & (co_obs  != -99999) &
        (g_alt   >= 0)  & (g_alt   != -99999) &
        (p_obs   >  0)  & (p_obs   != -99999) &
        (g_lat   >= gc_lat.min()) & (g_lat <= gc_lat.max()) &
        (g_lon   >= gc_lon.min()) & (g_lon <= gc_lon.max()) &
        (doy_arr >= 0)  & (doy_arr <= 364)
    )
    print(f"  Valid pts in GC domain: {valid.sum():,}")

    co_v  = co_obs[valid]
    alt_v = g_alt[valid] / 1000.0
    lat_v = g_lat[valid]
    lon_v = g_lon[valid]
    doy_v = doy_arr[valid]
    N     = len(co_v)

    # ── ATom bins ─────────────────────────────────────────────────
    atom_med = np.full(N_BINS, np.nan)
    atom_q25 = np.full(N_BINS, np.nan)
    atom_q75 = np.full(N_BINS, np.nan)
    atom_cnt = np.zeros(N_BINS, dtype=int)

    for b in range(N_BINS):
        mask_b = (alt_v >= alt_edges[b]) & (alt_v < alt_edges[b+1])
        vals = co_v[mask_b]
        atom_cnt[b] = len(vals)
        if len(vals) >= MIN_PTS:
            atom_med[b] = np.nanmedian(vals)
            atom_q25[b] = np.nanpercentile(vals, 25)
            atom_q75[b] = np.nanpercentile(vals, 75)

    # ── GC 完整列方法 ─────────────────────────────────────────────
    # 对每个 ATom 点找对应 GC 格点 (day, ilat, ilon)，去重后提取整列
    seen = set()
    gc_col_pool = [[] for _ in range(N_BINS)]   # 每个 bin 收集 GC CO 值

    for i in range(N):
        day  = int(doy_v[i])
        ilat = int(np.argmin(np.abs(gc_lat - lat_v[i])))
        ilon = int(np.argmin(np.abs(gc_lon - lon_v[i])))
        key  = (day, ilat, ilon)
        if key in seen:
            continue
        seen.add(key)

        gc_col = gc_co[day, :, ilat, ilon]   # 47层 CO ppb

        # 把整列按高度分配到各 bin
        for k in range(47):
            z = gc_alt_km[k]
            if z < 0 or z >= 12:
                continue
            b = int(z)          # floor → bin index (0-11)
            if 0 <= b < N_BINS:
                gc_col_pool[b].append(float(gc_col[k]))

    n_unique = len(seen)
    print(f"  Unique GC grid cells sampled : {n_unique:,}")

    gc_med = np.full(N_BINS, np.nan)
    gc_q25 = np.full(N_BINS, np.nan)
    gc_q75 = np.full(N_BINS, np.nan)
    gc_cnt = np.zeros(N_BINS, dtype=int)

    for b in range(N_BINS):
        vals = np.array(gc_col_pool[b])
        gc_cnt[b] = len(vals)
        if len(vals) >= MIN_PTS:
            gc_med[b] = np.nanmedian(vals)
            gc_q25[b] = np.nanpercentile(vals, 25)
            gc_q75[b] = np.nanpercentile(vals, 75)

    for b in range(N_BINS):
        print(f"    bin {alt_edges[b]:.0f}–{alt_edges[b+1]:.0f}km : "
              f"ATom n={atom_cnt[b]:4d} med={atom_med[b]:.1f}  |  "
              f"GC cells={gc_cnt[b]:4d} med={gc_med[b]:.1f}")

    results[camp] = dict(
        label   = info['label'],
        color_a = info['color_a'], color_m = info['color_m'],
        alt     = alt_centers,
        atom_med=atom_med, atom_q25=atom_q25, atom_q75=atom_q75,
        atom_cnt=atom_cnt,
        gc_med  =gc_med,   gc_q25  =gc_q25,   gc_q75  =gc_q75,
        gc_cnt  =gc_cnt,
    )
    ds.close()

ds_gc.close()

# ── 3. 画图 ───────────────────────────────────────────────────────
print("\nRendering figure …")
fig, axes = plt.subplots(1, 2, figsize=(10, 8),
                         sharey=True, constrained_layout=True)

fig.suptitle(
    'CO Vertical Profile:  ATom Observations vs. GEOS-Chem\n'
    'North America (10–60°N, 55–132°W)  |  '
    'GC: full-column sampling at ATom-matched grid cells (deduplicated)',
    fontsize=10.5, fontweight='bold'
)

CAMP_KEYS = ['ATom-2', 'ATom-3']
subtitles  = ['(a) Boreal Winter  (Jan–Feb 2017)', '(b) Boreal Fall  (Sep–Oct 2017)']

for ax, camp, subtitle in zip(axes, CAMP_KEYS, subtitles):
    r   = results[camp]
    alt = r['alt']
    va  = ~np.isnan(r['atom_med'])
    vg  = ~np.isnan(r['gc_med'])

    # GC
    ax.fill_betweenx(alt[vg], r['gc_q25'][vg], r['gc_q75'][vg],
                     color=r['color_m'], alpha=0.20)
    ax.plot(r['gc_med'][vg], alt[vg],
            color=r['color_m'], lw=2.2, ls='--', marker='s', ms=5,
            label='GEOS-Chem (median ± IQR)', zorder=3)

    # ATom
    ax.fill_betweenx(alt[va], r['atom_q25'][va], r['atom_q75'][va],
                     color=r['color_a'], alpha=0.18)
    ax.plot(r['atom_med'][va], alt[va],
            color=r['color_a'], lw=2.2, marker='o', ms=5,
            label='ATom (median ± IQR)', zorder=4)

    # 标注样本量
    for b in range(N_BINS):
        if r['atom_cnt'][b] >= MIN_PTS:
            ax.annotate(f"n={r['atom_cnt'][b]}",
                xy=(1.01, alt[b] / 12), xycoords=('axes fraction','axes fraction'),
                fontsize=6.5, color='#555555', va='center')

    ax.set_title(subtitle, fontsize=10.5, pad=6)
    ax.set_xlabel('CO Mixing Ratio (ppb)', fontsize=10.5)
    ax.set_ylim(0, 12)
    ax.set_xlim(left=0)
    ax.yaxis.set_major_locator(mticker.MultipleLocator(2))
    ax.yaxis.set_minor_locator(mticker.MultipleLocator(1))
    ax.grid(True, which='major', ls='--', alpha=0.45)
    ax.grid(True, which='minor', ls=':', alpha=0.25)
    ax.legend(loc='upper right', framealpha=0.85)

axes[0].set_ylabel('Altitude (km)', fontsize=10.5)

fig.text(0.50, -0.01,
    'ATom: binned by GPS altitude (1-km bins).  '
    'GEOS-Chem: all 47 levels of each matched (day, lat, lon) column, '
    'converted to altitude via std. atmosphere.',
    ha='center', fontsize=7.8, color='#444', style='italic')

outfile = 'CO_vertical_profile_ATom_vs_GEOSChem_v2.png'
plt.savefig(outfile, dpi=200, bbox_inches='tight', facecolor='white')
print(f"Saved → {outfile}")
plt.show()

